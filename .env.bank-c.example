# Example env file for running a THIRD bank instance alongside
# the default stack (bank A) and a second instance (bank B).
#
#   cp .env.bank-c.example .env.bank-c
#   docker compose --env-file .env.bank-c -f docker-compose.yml -f docker-compose.bank-b.yml up
#
# Reuses docker-compose.bank-b.yml — that override file clears every
# published port except the api-gateway's, so the same override works
# for any number of additional bank instances. Distinct stacks differ
# only in the env-file values.
COMPOSE_PROJECT_NAME=exbanka-c

# 3-digit bank code: must be unique across the cohort (bank A is 111,
# bank B is 222, this stack is 333).
OWN_BANK_CODE=333

# Gateway host ports: bank A uses 8080/9100; bank B uses 8081/9112;
# this stack uses 8082/9113. Pick non-colliding values for further
# instances (avoid 9100-9111 which bank A's per-service metrics use).
GATEWAY_HOST_PORT=8082
GATEWAY_METRICS_HOST_PORT=9113

# Distinct seed admin so login does not collide with bank A or B if
# the same test harness probes all three.
ADMIN_EMAIL=admin+bankc@admin.com
ADMIN_PASSWORD=AdminAdmin2026!.
