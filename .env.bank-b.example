# Example env file for running a SECOND bank instance alongside the
# default stack (bank A). Copy to .env.bank-b and adjust as needed:
#
#   cp .env.bank-b.example .env.bank-b
#   docker compose --env-file .env.bank-b -f docker-compose.yml -f docker-compose.bank-b.yml up
#
# COMPOSE_PROJECT_NAME namespaces all containers, networks, and volumes,
# so this stack does not collide with bank A's exbanka project.
COMPOSE_PROJECT_NAME=exbanka-b

# 3-digit bank code: must be unique across the cohort. Account numbers
# minted by this instance are prefixed with this value, and SI-TX
# routing-numbers are derived from it.
OWN_BANK_CODE=222

# Gateway host ports: must not collide with bank A (which uses 8080/9100).
# Bank A also publishes 9100-9111 for its 12 services' metrics, so pick
# 9112+ for bank B's gateway metrics. Peer banks reach this instance via
# http://host.docker.internal:8081/api/v3 — the SI-TX path prefix
# is part of the registered base_url because the outbound clients only
# append leaf names (/interbank, /public-stock, /negotiations), letting
# cohort banks with different gateway path layouts all interop.
GATEWAY_HOST_PORT=8081
GATEWAY_METRICS_HOST_PORT=9112

# Distinct seed admin so login does not collide with bank A's admin
# (each stack has its own user_db, but if you run integration tests
# against both stacks from a shared test harness, distinct credentials
# keep things unambiguous).
ADMIN_EMAIL=admin+bankb@admin.com
ADMIN_PASSWORD=AdminAdmin2026!.
